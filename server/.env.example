# ============================================
# FitFlow Caraguá — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Banco de Dados (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=fitflow_caragua

# --- JWT ---
JWT_SECRET=sua_chave_secreta_jwt_aqui_mude_em_producao
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=sua_chave_refresh_aqui_mude_em_producao
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Prisma (Database URL) ---
DATABASE_URL="mysql://root:sua_senha@localhost:3306/fitflow_caragua"
